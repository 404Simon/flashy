# Database
DATABASE_URL=sqlite:flashy.db

# Admin bootstrap (created on first start if no admin exists)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@example.com

# Session cookie settings
SESSION_SAME_SITE=lax
SESSION_SECURE=false

# MinIO storage
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=flashy
MINIO_FORCE_PATH_STYLE=true
MINIO_KEY_PREFIX=projects

# File upload limits
MAX_UPLOAD_SIZE_MB=100
MAX_PDF_SIZE_MB=50

# AI generation limits
MAX_CONTEXT_WORDS=12000

# LLM provider for AI flashcard generation
# Supported: openai, anthropic, deepseek, ollama, xai, google, groq, mistral, openrouter, cohere, phind, huggingface, aws_bedrock, azure_openai
LLM_PROVIDER=deepseek
LLM_API_KEY=your_api_key_here
LLM_MODEL=deepseek-chat
